@model StudentRecordMS.Models.Student
@{
    ViewBag.Title = "Add Student";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-success text-white">
            <h4><i class="fa-solid fa-user-plus me-2"></i>Add New Student</h4>
        </div>
        <div class="card-body">
            <form asp-controller="Invigilators" asp-action="Create" method="post" autocomplete="off">

                
                @**@
                <input type="text" style="display:none">
                <input type="password" style="display:none">

                <!-- Roll Number (auto) -->
                <div class="mb-3">
                    <label class="form-label">Roll Number</label>
                    <input type="text" class="form-control" value="@ViewBag.NextRollNumber" readonly />
                </div>

                <!-- Name -->
                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" placeholder="Enter student name" autocomplete="new-name" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <!-- Marks Row -->
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="Maths" class="form-label"></label>
                        <input asp-for="Maths" type="number" class="form-control" placeholder="1 - 100" autocomplete="off" />
                        <span asp-validation-for="Maths" class="text-danger"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Physics" class="form-label"></label>
                        <input asp-for="Physics" type="number" class="form-control" placeholder="1 - 100" autocomplete="off" />
                        <span asp-validation-for="Physics" class="text-danger"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Chemistry" class="form-label"></label>
                        <input asp-for="Chemistry" type="number" class="form-control" placeholder="1 - 100" autocomplete="off" />
                        <span asp-validation-for="Chemistry" class="text-danger"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="English" class="form-label"></label>
                        <input asp-for="English" type="number" class="form-control" placeholder="1 - 100" autocomplete="off" />
                        <span asp-validation-for="English" class="text-danger"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Programming" class="form-label"></label>
                        <input asp-for="Programming" type="number" class="form-control" placeholder="1 - 100" autocomplete="off" />
                        <span asp-validation-for="Programming" class="text-danger"></span>
                    </div>
                </div>

                <button type="submit" class="btn btn-success">
                    <i class="fa-solid fa-floppy-disk"></i> Save Student
                </button>
                <a asp-controller="Invigilators" asp-action="List" class="btn btn-secondary ms-2">
                    Back to List
                </a>
            </form>
        </div>
    </div>
    

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    
    <script>
        document.querySelectorAll("input").forEach(input => {
            input.addEventListener("focus", function () {
                this.setAttribute("autocomplete", "off");
            });
        });
    </script>
   

}
