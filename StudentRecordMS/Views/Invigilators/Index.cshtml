@{
    ViewBag.Title = "Invigilator Dashboard";
}

<div class="container mt-4">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    <div style="position:absolute; top:10px; right:10px;">
        <a href="@Url.Action("Logout", "Invigilators")" class="btn btn-danger">
            <i class="fa-solid fa-right-from-bracket"></i> Logout
        </a>
    </div>

    <h3 class="mb-4 text-center">Welcome, @ViewBag.UserName</h3>

    <div class="row justify-content-center">
        <div class="col-md-4 mb-3">
            <div class="card shadow h-100">
                <div class="card-body d-flex flex-column align-items-center justify-content-center" style="min-height:140px;">
                    <i class="fa-solid fa-list fa-2x mb-3 text-primary"></i>
                    <a asp-controller="Invigilators" asp-action="List" class="btn btn-primary">
                        View All Students
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card shadow h-100">
                <div class="card-body d-flex flex-column align-items-center justify-content-center" style="min-height:140px;">
                    <i class="fa-solid fa-user-plus fa-2x mb-3 text-success"></i>
                    <a asp-controller="Invigilators" asp-action="Create" class="btn btn-success">
                        Add Student
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>